# ============================================
# OpenAI / LLM API 配置
# ============================================
# API 地址，兼容任何 OpenAI 格式的 API（如 Azure、vLLM、Ollama 等）
# 默认: https://api.openai.com/v1
API_BASE_URL=https://api.openai.com/v1

# API 密钥
API_KEY=sk-your-key-here

# 字幕翻译/摘要生成使用的模型名称
# 默认: gpt-4o-mini
MODEL=gpt-4o-mini

# ============================================
# Whisper 语音识别配置（transcribe.py）
# ============================================
# Whisper 模型大小: tiny / base / small / medium / large-v3
# 越大越准越慢，默认 base 即可
WHISPER_MODEL=base

# 推理设备: auto / cpu / cuda
WHISPER_DEVICE=auto

# 计算精度: auto / float16 / int8_float16
WHISPER_COMPUTE_TYPE=auto

# ============================================
# 输出目录
# ============================================
# 所有生成文件的根目录，每个视频会按 video_id 建子文件夹
# 默认: output
OUTPUT_DIR=output
